<Window
    x:Class="WinUI3.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- 自定义标题栏 -->
        <Grid x:Name="TitleBarArea"
              Height="32"
              Background="Transparent"
              VerticalAlignment="Top">
            <TextBlock x:Name="TitleBarAppName"
                       VerticalAlignment="Center"
                       Margin="16,0"
                       FontSize="14"/>
        </Grid>

        <!-- 主内容区域 -->
        <Grid Margin="0,32,0,0">
            <NavigationView x:Name="NavView"
                            PaneDisplayMode="Auto"
                            IsSettingsVisible="True"
                            IsBackButtonVisible="Visible"
                            BackRequested="NavView_BackRequested"
                            ItemInvoked="NavView_ItemInvoked">
                <NavigationView.MenuItems>
                    <NavigationViewItem x:Uid="HomeItem" Tag="home">
                        <NavigationViewItem.Icon>
                            <FontIcon Glyph="&#xE80F;"/>
                        </NavigationViewItem.Icon>
                    </NavigationViewItem>
                </NavigationView.MenuItems>
                <Frame x:Name="ContentFrame"/>
            </NavigationView>
        </Grid>

        <!-- Splash 遮罩 -->
        <Grid x:Name="SplashOverlay"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
              Visibility="Collapsed"
              Opacity="0">
            <Grid.Resources>
                <!-- 淡入动画：纯色到启动屏幕 -->
                <Storyboard x:Name="SplashFadeIn">
                    <DoubleAnimation Storyboard.TargetName="ColorOverlay"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0"
                                     Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                
                <!-- 淡出动画：启动屏幕到主界面 -->
                <Storyboard x:Name="SplashFadeOut">
                    <DoubleAnimation Storyboard.TargetName="SplashOverlay"
                                     Storyboard.TargetProperty="Opacity"
                                     From="1" To="0"
                                     Duration="0:0:0.3">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
            
            <!-- 启动屏幕图片 -->
            <Image Source="ms-appx:///Assets/SplashScreen.png"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Stretch="None"/>
            
            <!-- 纯色遮罩层（根据主题自动切换黑白） -->
            <Rectangle x:Name="ColorOverlay"
                       Fill="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                       Opacity="1"/>
        </Grid>
    </Grid>
</Window>