<Page
    x:Class="WinUI3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls">

    <ScrollViewer Padding="20,20,20,0">

        <StackPanel Spacing="32">

            <StackPanel Spacing="3">
                <TextBlock x:Uid="AppearanceGroup"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <Expander IsExpanded="False"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           MinHeight="74">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE706;" Width="25" FontSize="20"/>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock x:Uid="ThemeTitle"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                                <TextBlock x:Uid="ThemeSubtitle"
                                       FontSize="12"
                                       Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander.Header>
                    <RadioButtons x:Name="RbTheme"
                                  SelectionChanged="RbTheme_SelectionChanged"
                                  Padding="12,0,0,12">
                        <RadioButton x:Uid="ThemeSystem" Tag="System"/>
                        <RadioButton x:Uid="ThemeLight" Tag="Light"/>
                        <RadioButton x:Uid="ThemeDark" Tag="Dark"/>
                    </RadioButtons>
                </Expander>

                <Expander IsExpanded="False"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           MinHeight="74">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE2B1;" Width="25" FontSize="20"/>
                            <StackPanel Margin="6,0,0,0">
                                <TextBlock x:Uid="MaterialTitle"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                                <TextBlock x:Uid="MaterialSubtitle"
                                       FontSize="12"
                                       Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander.Header>
                    <RadioButtons x:Name="RbMaterial"
                                  SelectionChanged="RbMaterial_SelectionChanged"
                                  Padding="12,0,0,12">
                        <RadioButton Content="Mica" Tag="Mica"/>
                        <RadioButton Content="Mica Alt" Tag="MicaAlt"/>
                        <RadioButton Content="Acrylic" Tag="Acrylic"/>
                    </RadioButtons>
                </Expander>
            </StackPanel>

            <StackPanel Spacing="3">
                <TextBlock x:Uid="NavGroup"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <controls:SettingsCard x:Uid="Settings_NavCard" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                       MinHeight="74" Padding="16,0">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE700;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ComboBox x:Name="PanePositionCombo"
                              Width="160"
                              HorizontalAlignment="Right"
                              SelectionChanged="PanePositionCombo_SelectionChanged">
                        <ComboBoxItem x:Uid="PanePositionLeft"/>
                        <ComboBoxItem x:Uid="PanePositionTop"/>
                    </ComboBox>
                </controls:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="3">
                <TextBlock x:Uid="SoundGroup"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <controls:SettingsCard x:Uid="Settings_SoundCard" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                       MinHeight="74" Padding="16,0">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE767;" />
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch x:Name="SoundToggle"
                                  HorizontalAlignment="Right"
                                  Toggled="SoundToggle_Toggled"/>
                </controls:SettingsCard>
            </StackPanel>

            <StackPanel Spacing="3">
                <TextBlock x:Uid="AboutGroup"
                       FontSize="20"
                       FontWeight="SemiBold"/>

                <Expander IsExpanded="False"
                           HorizontalAlignment="Stretch"
                           HorizontalContentAlignment="Left"
                           MinHeight="94">
                    <Expander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image x:Name="ImgAppIcon"
                               Width="20"
                               Height="20"
                               Stretch="Uniform"
                               Margin="4,0,4,0"/>
                            <StackPanel>
                                <TextBlock x:Name="TxtAppName"
                                       FontSize="14"
                                       FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtCopyright"
                                       FontSize="12"
                                       Opacity="0.7"/>
                                <TextBlock x:Name="TxtVersion"
                                       FontSize="14"
                                       Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander.Header>
                    <StackPanel>
                        <HyperlinkButton Click="OpenLink_Click"
                                     Tag="https://qm.qq.com/q/UPnTGW164m"
                                     HorizontalAlignment="Left">
                            <TextBlock x:Uid="QQGroup" VerticalAlignment="Center"/>
                        </HyperlinkButton>
                        <HyperlinkButton Click="OpenLink_Click"
                                     Tag="https://discord.gg/4NScc8sEzw"
                                     HorizontalAlignment="Left">
                            <TextBlock x:Uid="DiscordGroup" VerticalAlignment="Center"/>
                        </HyperlinkButton>
                    </StackPanel>
                </Expander>

                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,20,0,20">
                    <FontIcon Glyph="&#xED15;" FontSize="20" VerticalAlignment="Center"/>
                    <HyperlinkButton Click="OpenLink_Click"
                                     Tag="https://forms.office.com/r/jzsFaQKCpr"
                                     Padding="0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center">
                        <TextBlock x:Uid="Feedback"/>
                    </HyperlinkButton>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>