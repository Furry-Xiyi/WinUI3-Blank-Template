<Page
    x:Class="WinUI3.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:local="using:WinUI3.Constants">

    <Page.Resources>
        <x:Double x:Key="SettingsCardSpacing">4</x:Double>

        <Style x:Key="SettingsSectionHeaderTextBlockStyle"
               BasedOn="{StaticResource BodyStrongTextBlockStyle}"
               TargetType="TextBlock">
            <Style.Setters>
                <Setter Property="Margin" Value="1,16,0,6" />
            </Style.Setters>
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <Grid Padding="20,8,20,20">
            <StackPanel MaxWidth="1000" Spacing="{StaticResource SettingsCardSpacing}">
                <StackPanel.ChildrenTransitions>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                    <RepositionThemeTransition IsStaggeringEnabled="True" />
                </StackPanel.ChildrenTransitions>

                <!-- 外观组 -->
                <TextBlock x:Uid="AppearanceGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <!-- 主题 -->
                <controls:SettingsExpander x:Uid="ThemeSettingsExpander" IsExpanded="False">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE706;"/>
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Left">
                            <RadioButtons x:Name="RbTheme"
                                          SelectionChanged="RbTheme_SelectionChanged">
                                <RadioButton x:Uid="ThemeSystem" Tag="System"/>
                                <RadioButton x:Uid="ThemeLight" Tag="Light"/>
                                <RadioButton x:Uid="ThemeDark" Tag="Dark"/>
                            </RadioButtons>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- 背景材质 -->
                <controls:SettingsExpander x:Uid="MaterialSettingsExpander" IsExpanded="False">
                    <controls:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE2B1;"/>
                    </controls:SettingsExpander.HeaderIcon>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard ContentAlignment="Left">
                            <RadioButtons x:Name="RbMaterial"
                                          SelectionChanged="RbMaterial_SelectionChanged">
                                <RadioButton x:Uid="MaterialMica" Tag="Mica"/>
                                <RadioButton x:Uid="MaterialMicaAlt" Tag="MicaAlt"/>
                                <RadioButton x:Uid="MaterialAcrylic" Tag="Acrylic"/>
                            </RadioButtons>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- 导航栏组 -->
                <TextBlock x:Uid="NavGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="NavSettingsCard">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF594;"/>
                    </controls:SettingsCard.HeaderIcon>
                    <ComboBox x:Name="PanePositionCombo"
                              Width="160"
                              SelectionChanged="PanePositionCombo_SelectionChanged">
                        <ComboBoxItem x:Uid="PanePositionLeft"/>
                        <ComboBoxItem x:Uid="PanePositionTop"/>
                    </ComboBox>
                </controls:SettingsCard>

                <!-- 声音组 -->
                <TextBlock x:Uid="SoundGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsCard x:Uid="SoundSettingsCard">
                    <controls:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xEC4F;"/>
                    </controls:SettingsCard.HeaderIcon>
                    <ToggleSwitch x:Name="SoundToggle"
                                  Toggled="SoundToggle_Toggled"/>
                </controls:SettingsCard>

                <!-- 关于组 -->
                <TextBlock x:Uid="AboutGroup"
                           Style="{StaticResource SettingsSectionHeaderTextBlockStyle}"/>

                <controls:SettingsExpander IsExpanded="False">
                    <controls:SettingsExpander.Header>
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Image x:Name="ImgAppIconSettings" Width="32" Height="32"/>
                            <StackPanel>
                                <TextBlock x:Name="TxtAppName" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtCopyright" FontSize="12" Opacity="0.7"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:SettingsExpander.Header>
                    <TextBlock x:Name="TxtVersion"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               IsTextSelectionEnabled="True"/>
                    <controls:SettingsExpander.Items>
                        <controls:SettingsCard HorizontalContentAlignment="Left" ContentAlignment="Left">
                            <StackPanel Margin="-12,0,0,0" Spacing="4">
                                <HyperlinkButton Click="OpenExternalLink"
                                                 Tag="{x:Bind local:AppLinks.QQGroup}">
                                    <TextBlock x:Uid="QQGroup"/>
                                </HyperlinkButton>
                                <HyperlinkButton Click="OpenExternalLink"
                                                 Tag="{x:Bind local:AppLinks.Discord}">
                                    <TextBlock x:Uid="DiscordGroup"/>
                                </HyperlinkButton>
                            </StackPanel>
                        </controls:SettingsCard>
                    </controls:SettingsExpander.Items>
                </controls:SettingsExpander>

                <!-- 发送反馈 -->
                <HyperlinkButton Click="OpenExternalLink"
                                 Tag="{x:Bind local:AppLinks.Feedback}"
                                 Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xED15;" FontSize="16"/>
                        <TextBlock x:Uid="Feedback"/>
                    </StackPanel>
                </HyperlinkButton>

            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
